# Copy this file to .env and fill in your own values.
# .env is gitignored; it holds deployment details that shouldn't be published.

# SSH destination for installer\upload.ps1 (user@host, or an alias from ~/.ssh/config)
AUTOMOUSE_UPLOAD_TARGET=user@example.com

# Absolute path of the directory to upload into
AUTOMOUSE_UPLOAD_DIR=/var/www/example.com/cdn

# Where that directory is served from, used to print the download links
AUTOMOUSE_PUBLIC_BASE=https://example.com/cdn
